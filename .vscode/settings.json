{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "always"
  },
  "css.validate": false,
  "tailwindCSS.experimental.classRegex": [
    "class(?:Name)?=\\\"([^\\\"]*)\\\"",
    "class:\\s*\\`([^\\`]*)\\`"
  ],
  "tailwindCSS.emmetCompletions": true,
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
