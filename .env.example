NEXT_PUBLIC_BACKEND_URL="BACKEND_URL"

# Environment flag ("1" = production, "0" = test/development)
NEXT_PUBLIC_IS_PRODUCTION="0"

# Environment flag for build
NODE_ENV="development"

# PayU Configuration
NEXT_PUBLIC_PAY_U_KEY_TEST="PAYU_TEST_KEY"
NEXT_PUBLIC_PAY_U_KEY_PROD="PAYU_PROD_KEY"

# App URL (used for PayU success/failure redirects)
NEXT_PUBLIC_APP_URL="REDIRECT_URL"

# PostHog Configuration
NEXT_PUBLIC_POSTHOG_KEY="POSTHOG_KEY"
NEXT_PUBLIC_POSTHOG_HOST="POSTHOG_HOST"